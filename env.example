# ⚠️ IMPORTANTE: ESTE ES UN TEMPLATE
# ====================================
# NO subas el archivo .env con tus credenciales reales a GitHub
# 
# Pasos:
# 1. Copia este archivo: cp .env.example .env
# 2. Edita .env con tus credenciales REALES
# 3. .env está en .gitignore y NO se subirá a GitHub
# 4. Solo .env.example (este archivo) se sube al repo

# POLAR ACCESSLINK API CREDENTIALS
# =================================
# Obtén tus credenciales en: https://admin.polaraccesslink.com/

POLAR_CLIENT_ID=your_client_id_here
POLAR_CLIENT_SECRET=your_client_secret_here

# Nombre para archivos RR (sin espacios)
POLAR_USER_NAME=Your_Name

# CONFIGURACIÓN OPCIONAL
# ======================

# URL pública (Railway/Render lo configuran automáticamente)
# PUBLIC_URL=https://tu-app.up.railway.app

# Directorio base de datos CSV (default recomendado)
# HRV_DATA_DIR=data

# Directorio donde se guardan archivos RR descargados
# RR_DOWNLOAD_DIR=data/rr_downloads

# Deportes a filtrar (separados por coma)
# SPORT_FILTER=BODY_AND_MIND,YOGA,MEDITATION

# Duración máxima en minutos (sesiones más largas se ignoran)
# MAX_DURATION_MINUTES=10

# INSTRUCCIONES DE USO
# ====================
#
# LOCAL (Portátil):
# 1. cp .env.example .env
# 2. Editar .env con credenciales reales
# 3. python polar_hrv_automation.py --auth
#
# RAILWAY/RENDER:
# 1. NO uses .env en producción
# 2. Configura variables de entorno en el dashboard:
#    - POLAR_CLIENT_ID
#    - POLAR_CLIENT_SECRET
#    - POLAR_USER_NAME
#
# SEGURIDAD:
# - .env está en .gitignore
# - NUNCA subas .env a GitHub
# - Solo .env.example (este archivo) va al repo
# - Si subes .env por error, rota credenciales INMEDIATAMENTE
